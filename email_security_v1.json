        "jsCode": "const aiResponse = $input.item.json.response;\n\n// 1. Sanitize: Remove Markdown code blocks and whitespace\nconst cleanJson = aiResponse.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n\ntry {\n  // 2. Parse\n  const parsedData = JSON.parse(cleanJson);\n  \n  return {\n    subject: $input.item.json.subject,\n    // Default to score 0 if missing\n    priority_score: parsedData.priority_score || 0, \n    // Force boolean\n    is_important: parsedData.is_important === true, \n    reasoning: parsedData.reasoning\n  };\n} catch (error) {\n  // If AI sends garbage, flag it as an error but don't crash\n  return {\n    error: \"AI JSON Parse Failed\",\n    raw_output: aiResponse,\n    is_important: false\n  };\n}"
